Bootstrap: docker
From: python:3.10-slim

%setup
    mkdir -p $APPTAINER_ROOTFS/BioPathNet


%files


%post
    # Update the available packages list.
    apt -y update
    # And add the "universe" repository (allow to install many more software).
    # apt -y install software-properties-common time
    # add-apt-repository universe
    # apt -y update
    # Update the operating systems (install last versions with bugfixes).
    # apt -y dist-upgrade

    # Install dependencies for your project.
    apt -y install curl bash git libxrender1

    apt -y install python3-pip
    pip install --upgrade pip

    pip install --no-cache-dir torch==2.0.1+cu118 torchvision==0.15.2+cu118 torchaudio==2.0.2+cu118 -f https://download.pytorch.org/whl/torch_stable.html
    pip install --no-cache-dir pyg_lib torch_scatter torch_sparse torch_cluster torch_spline_conv -f https://data.pyg.org/whl/torch-2.0.1+cu118.html
    pip install git+https://github.com/DeepGraphLearning/torchdrug
    pip install ogb easydict pyyaml
    pip install numpy==1.26.4 --force-reinstall

    # Torch needs to install some stuff in /root/.cache
    # so we need to let it do it while the cache is not in read-only.
    # We just execute the help to do so.
    python3 /BioPathNet/script/run.py --help

    # Clean-up of the APT cache (will lighten the container).
    # apt -y purge software-properties-common curl
    # apt -y --purge autoremove
    # apt -y autoclean
    # apt clean


%environment
    export APPTAINER_SHELL=/bin/bash


%runscript
    #!/bin/bash

    SCRIPT=$1
    CONFIG=$2
    GPUS=$3

    if [[ $1 == "script/run.py" ]] ; then
        if [[ $# -eq 5 ]] ; then
           $SCRIPT -c $CONFIG --gpus $GPUS
        else
            if [[ $# -eq 4 ]] ; then
                SEED=$4
               $SCRIPT -s $SEED -c $CONFIG --gpus $GPUS
            fi
        fi
    fi


%test
   python3 /BioPathNet/script/run.py --help


%labels
    Author Claire Laudy
    Author Johann Dreo
